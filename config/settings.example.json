{
  "paths": {
    "repo_root": "/absolute/path/to/your/repo",
    "memory_root": "/absolute/path/to/your/private/memory",
    "browser_profile_root": "/absolute/path/to/your/private/browser-profile"
  },
  "dashboard": {
    "assistant_refresh_seconds": 60,
    "x_refresh_seconds": 30,
    "reddit_refresh_seconds": 60
  },
  "providers": {
    "openai_enabled": false,
    "anthropic_enabled": false
  },
  "feeds": {
    "x_enabled": false,
    "reddit_enabled": true
  },
  "reddit": {
    "subreddit": "MachineLearning",
    "listing": "hot",
    "max_posts": 12,
    "mock_input": "raw/inbox/reddit-ml-visible-posts.example.json"
  }
}
